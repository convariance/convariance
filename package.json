{
  "name": "convariance",
  "version": "0.1.0",
  "private": true,
  "description": "Put Claude Code (or any MCP agent) in your live conversation — transcript in, typed inline contributions out.",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "clean": "turbo run clean",
    "build": "turbo run build",
    "prepack": "turbo run prepack",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "eslint --fix .",
    "test": "node --test \"packages/*/src/**/*.test.ts\"",
    "smoke": "node packages/gateway/test/smoke.ts",
    "check": "pnpm run typecheck && pnpm run lint",
    "gateway": "node packages/gateway/src/bin.ts",
    "changeset": "changeset",
    "release": "pnpm run build && changeset publish",
    "publish:all": "pnpm publish -r --access public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.1"
  }
}
