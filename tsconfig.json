{
  // One buildless, no-emit typecheck for everything: src, tests, smoke
  // fixtures, the ui app, and the tool configs. tsdown owns the dist/ emit
  // (JS via rolldown, d.ts via its dts plugin reading this file). The `paths`
  // mapping pins the package self-name at its SOURCE entry — the ui imports
  // `convariance` and always typechecks against fresh src/, never stale dist.
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "convariance": ["src/index.ts"],
      "convariance/agent": ["src/agent.ts"]
    }
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts",
    "ui/src/**/*.ts",
    "ui/vite.config.ts",
    "tsdown.config.ts"
  ]
}
